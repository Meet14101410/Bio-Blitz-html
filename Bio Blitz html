<!DOCTYPE html>
<html lang="en">
<head>
    <title>Bio Blitz</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>

    <div class="quiz-container">
        <h1>🧬 Bio Blitz</h1>

        <div id="question-box">
            <p id="question">
                What is the basic unit of life?
            </p>

            <div class="options">
                <button onclick="checkAnswer('A')">A. Tissue</button>
                <button onclick="checkAnswer('B')">B. Cell</button>
                <button onclick="checkAnswer('C')">C. Organ</button>
                <button onclick="checkAnswer('D')">D. System</button>
            </div>

            <p id="result"></p>
        </div>

        <button onclick="nextQuestion()">Next</button>
    </div>

    <script src="script.js"></script>

</body>
</html>
